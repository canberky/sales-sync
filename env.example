# ── Shopify ──────────────────────────────────────────────────
# Your store subdomain (no https://)
SHOPIFY_STORE=mystore.myshopify.com
# Admin API access token (Settings → Apps → Develop apps)
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Square ───────────────────────────────────────────────────
# Production access token (developer.squareup.com)
SQUARE_ACCESS_TOKEN=EAAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Leave blank to pull from all locations
SQUARE_LOCATION_ID=

# ── Supabase ─────────────────────────────────────────────────
# Project URL  (Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# service_role secret key — KEEP THIS PRIVATE (bypasses RLS for writes)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Telegram ─────────────────────────────────────────────────
# Create a bot via @BotFather, copy the token
TELEGRAM_BOT_TOKEN=1234567890:ABCDefghIJKlmnOPQrstUVwxyz
# Your chat/channel ID; use @channelusername or numeric -100xxxxxxxxxx
TELEGRAM_CHAT_ID=@mystore_reports
